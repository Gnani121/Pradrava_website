# SMTP configuration for contact form emails
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Recipient and sender
CONTACT_TO_EMAIL=info@pradrava.com
CONTACT_FROM_EMAIL=no-reply@pradrava.com

# Optional: also forward submissions to a webhook
# CONTACT_WEBHOOK_URL=https://your-webhook-endpoint.example.com/contact

# Supabase configuration for demo OTP storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Schema used by Supabase client (must be exposed in Supabase API settings)
SUPABASE_DB_SCHEMA=public
# OTP table name inside selected schema
# SUPABASE_OTP_TABLE=otp_codes

# Demo launch target for verified users
FLUIDS_APP_URL=https://fluids-v3.example.com

# Demo JWT signing configuration
DEMO_JWT_KID=demo-2026-05
DEMO_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
DEMO_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Keep false in production; set true only for temporary local fallback
DEMO_OTP_ALLOW_MEMORY_FALLBACK=false
